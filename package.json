{
  "name": "desktop-pet-mvp",
  "version": "0.1.0",
  "description": "一个安静住在 macOS 桌面上的小伙伴（v0.1 MVP）",
  "main": "./out/main/main.js",
  "author": "czy",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "build": "pnpm typecheck && electron-vite build",
    "dist:mac": "pnpm build && electron-builder --mac --publish never"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "@electron/osx-sign": "^1.3.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "ogl": "^1.0.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.185.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  }
}
